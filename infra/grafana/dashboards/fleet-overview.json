{
  "uid": "fleet-overview",
  "title": "FleetIQ — Fleet Overview",
  "tags": ["fleetiq"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "GPUs Up",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(gpu_up)", "refId": "A", "instant": true}
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "red"},
              {"value": 1, "color": "yellow"},
              {"value": 4, "color": "green"}
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "background",
        "textMode": "value"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total GPUs",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "count(gpu_up)", "refId": "A", "instant": true}
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "blue"}]},
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "background",
        "textMode": "value"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Fleet Avg Temp",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "avg(gpu_temperature_celsius)", "refId": "A", "instant": true}
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 70, "color": "yellow"},
              {"value": 85, "color": "red"}
            ]
          },
          "unit": "celsius",
          "decimals": 1
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "background",
        "textMode": "value"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total Fleet Power",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(gpu_power_watts)", "refId": "A", "instant": true}
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "blue"}]},
          "unit": "watt",
          "decimals": 0
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "background",
        "textMode": "value"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Temperature by GPU",
      "gridPos": {"x": 0, "y": 4, "w": 24, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "gpu_temperature_celsius", "refId": "A", "legendFormat": "{{gpu_id}}"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 70, "color": "yellow"},
              {"value": 85, "color": "red"}
            ]
          }
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull", "max"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Power Draw by GPU",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "gpu_power_watts", "refId": "A", "legendFormat": "{{gpu_id}}"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 20, "stacking": {"mode": "normal"}}
        }
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Utilization by GPU",
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "gpu_utilization_percent", "refId": "A", "legendFormat": "{{gpu_id}}"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10}
        }
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "ECC Corrected Errors (rate / sec)",
      "gridPos": {"x": 0, "y": 20, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "rate(gpu_ecc_errors_corrected_total[1m])", "refId": "A", "legendFormat": "{{gpu_id}}"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"drawStyle": "bars", "lineWidth": 1, "fillOpacity": 80}
        }
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "ECC Uncorrected Errors (cumulative)",
      "gridPos": {"x": 12, "y": 20, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "gpu_ecc_errors_uncorrected_total", "refId": "A", "legendFormat": "{{gpu_id}}"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 0}
        }
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "GPUs Down",
      "gridPos": {"x": 0, "y": 28, "w": 24, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "gpu_up == 0", "refId": "A", "legendFormat": "{{gpu_id}}", "instant": true}
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "red"}]},
          "noValue": "All GPUs healthy"
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": true},
        "colorMode": "background",
        "textMode": "value_and_name"
      }
    }
  ]
}
